{
  "extensions": ".py .toml .ini .env.example .dockerfile .yaml .sh",
  "ignored_paths": "__pycache__, venv, .venv, .git, .idea, .pytest_cache",
  "minify": true,
  "remove_comments": true,
  "remove_secrets": true,
  "include_tree": true,
  "use_git": false,
