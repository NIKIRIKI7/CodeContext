{
    "extensions": ".py .js .ts .vue .jsx .tsx .html .css .json .md .sql .xml .yaml .yml .sh .bat .go .java .cpp",
    "ignored_paths": ".git, node_modules, .nuxt, __pycache__, dist, build, .idea, .vscode, venv, .venv, coverage, .next, target, bin, obj",
    "minify": true,
    "remove_comments": true,
    "remove_secrets": true,
    "include_tree": false,
    "include_dependencies": false,
    "include_mermaid": false,
    "skeleton_mode": false,
    "use_git": false,
    "git_base": "",
    "use_gitignore": false,
    "system_prompt": "",
    "output_format": "plain",
    "template_path": "",
    "enable_logging": true,
    "external_editor": "",
    "receive_prereleases": false,
    "llm_check_enabled": false,
    "llm_base_url": "",
    "llm_model": "",
    "visible_tabs": [
        "sources",
        "filters",
        "prompts",
        "llm_os",
        "appearance"
    ],
    "visible_actions": [
        "preview",
        "clipboard",
        "chat",
        "editor",
        "file"
    ],
    "visible_checkboxes": [
        "dedup",
        "aggressive",
        "checkpoints",
        "watch"
    ],
    "language": "ru",
    "deduplicate": false,
    "save_checkpoints": false,
    "auto_watch": false,
    "prioritize_entry_files": true,
    "preserve_docstrings": false,
    "preserve_imports": false,
    "aggressive_minify": false,
    "approved_plugins": [
        "hello_world"
    ]
}